# Copy this file to .env and fill in real values.
# Generate a strong token:  node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_TOKEN=changeme

# The Xtream server customers plug into their IPTV player (your real streaming
# box — this landing page only sells/gates access, it does not serve video).
XTREAM_SERVER_URL=http://your-xtream-server:8080

# Optional: port the server listens on (defaults to 3000)
# PORT=3000

# Supabase — stores "request to join" submissions shown in /admin.
# Use the SERVICE ROLE key (Project Settings → API). It is server-side only —
# never expose it in the browser.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: table name (defaults to join_requests)
# SUPABASE_TABLE=join_requests

# Resend — transactional email (submission confirmation, approved, onboarding).
# Create an API key at https://resend.com/api-keys. RESEND_FROM must use a
# domain/subdomain you've verified in Resend (e.g. your noreply subdomain).
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=Manzar <noreply@your-subdomain.example.com>
